  "panels": [
    {
      "type": "timeseries",
      "title": "HTTP request rate (req/s) by URI",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (uri) (rate(http_server_requests_seconds_count{uri!~\"/actuator.*|/api/v1/dashboard/stream\"}[1m]))",
          "legendFormat": "{{uri}}"
        }
      ],
      "options": { "legend": { "displayMode": "table", "placement": "right" } }
    },
    {
      "type": "timeseries",
      "title": "p95 HTTP latency (s) by URI",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, uri) (rate(http_server_requests_seconds_bucket{uri!~\"/actuator.*|/api/v1/dashboard/stream\"}[5m])))",
          "legendFormat": "p95 {{uri}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "type": "stat",
      "title": "Kairos custom: rollup invocations / min",
      "gridPos": { "x": 0, "y": 8, "w": 6, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum(rate(kairos_rollup_objective_seconds_count[1m])) * 60" }
      ]
    },
    {
      "type": "stat",
      "title": "Kairos custom: SSE broadcasts / min",
      "gridPos": { "x": 6, "y": 8, "w": 6, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum(rate(kairos_sse_broadcast_seconds_count[1m])) * 60" }
      ]
    },
    {
      "type": "timeseries",
      "title": "JVM heap used (MB)",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (area) (jvm_memory_used_bytes{area=\"heap\"}) / 1024 / 1024",
          "legendFormat": "{{area}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "decmbytes" } }
    },
    {
      "type": "timeseries",
      "title": "Hikari pool — active vs idle vs pending",
      "gridPos": { "x": 0, "y": 14, "w": 24, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "hikaricp_connections_active",  "legendFormat": "active" },
        { "expr": "hikaricp_connections_idle",    "legendFormat": "idle" },
        { "expr": "hikaricp_connections_pending", "legendFormat": "pending" }
      ]
    }
  ],
